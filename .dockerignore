# Keep the Docker build context small and avoid sending local secrets or caches
# to the Docker daemon.

.dockerignore
.git
.gitignore

# Local caches and editor tooling
/.dependencies/
/.direnv/
/.elixir_ls/
/.opencode/
/result

# Mix/build artifacts
/_build/
/deps/
/cover/
/doc/
*.ez
erl_crash.dump

# Test and temporary files are not needed in the release image.
/test/
/tmp/

# Local secrets, credentials, and database dumps must never enter the build context.
.env*
.aws/
.ssh/
credentials.json
secrets/
*.dump
*.cert
*.crt
*.jks
*.key
*.keystore
*.pem
*.p12
*.pfx
*.sql
config/*.secret.exs

# Phoenix asset artifacts are rebuilt inside the image.
/assets/node_modules/
/priv/static/assets/
/priv/static/cache_manifest.json
